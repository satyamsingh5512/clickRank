# Production-oriented baseline (copy to .env for prod-like runs)
POSTGRES_USER=clickrank
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=clickrank_db

DB_HOSTS=postgres:5432
DB_USERNAME=clickrank
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_CLUSTER_NODES=redis:6379

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_JAAS_CONFIG=

CLICKRANK_BACKEND_URI=http://clickrank-backend:8081
OAUTH2_ISSUER_URI=https://your-issuer.example.com/realms/clickrank
GATEWAY_REQUIRE_AUTH=true

POSTGRES_URL=postgresql://clickrank:CHANGE_ME_STRONG_PASSWORD@postgres:5432/clickrank_db
LOG_LEVEL=INFO

SPRING_PROFILES_ACTIVE=prod
