# =============================================================================
# ClickRank — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   docker compose up -d
# =============================================================================


# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=clickrank
POSTGRES_PASSWORD=password
POSTGRES_DB=clickrank_db

# Used by the Spring services (dev profile uses single host, prod uses HA string)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=clickrank
DB_PASSWORD=password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Leave blank for no-auth (default dev setup). Set for production.
REDIS_USERNAME=default
REDIS_PASSWORD=

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
# PLAINTEXT for local dev, SASL_SSL for production
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
# Only needed when KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_JAAS_CONFIG=

# ─── Schema Registry (optional, Phase 5) ─────────────────────────────────────
SCHEMA_REGISTRY_URL=http://localhost:8085

# ─── API Gateway ──────────────────────────────────────────────────────────────
CLICKRANK_BACKEND_URI=http://clickrank-backend:8081

# ─── OAuth2 / JWT (optional, disabled in dev profile) ─────────────────────────
# Point to your Keycloak / Auth0 realm for production.
OAUTH2_ISSUER_URI=http://localhost:8082/realms/clickrank

# ─── ML Ranking Service (Python / FastAPI) ────────────────────────────────────
# Optional: enables pgvector semantic boosts. Leave blank to skip.
POSTGRES_URL=postgresql://clickrank:password@postgres:5432/clickrank_db
LOG_LEVEL=INFO

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# The URL the browser uses to reach the API gateway
VITE_API_BASE_URL=http://localhost:8080
